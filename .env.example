# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOOTSTRAP_CHAT_ID=your_chat_id

# Claude Code CLI
CLAUDE_CODE_PATH=claude
MIRA_SOUL_PATH=/home/user/agent-soul/FULL-CONTEXT.md

# API
API_PORT=3000
API_HOST=0.0.0.0

# Vector Memory (Pinecone + Cohere)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_HOST=your-index-name.svc.pinecone.io
COHERE_API_KEY=your_cohere_api_key

# Knowledge Graph (Groq for triple extraction)
GROQ_API_KEY=your_groq_api_key

# Database (for knowledge graph)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_platform

# Email (optional)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
